{
  "info": {
    "_postman_id": "8e7a1f3a-0000-4000-8000-000000000001",
    "name": "Measurement Conversion API",
    "description": "REST API for decoding measurement strings and managing conversion history.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Convert measurement (simple)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/conversion?input=babcdefaz",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversion"],
          "query": [{ "key": "input", "value": "babcdefaz" }]
        },
        "description": "Three packages: 3, 15, 26"
      }
    },
    {
      "name": "Convert measurement (z continuation)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/conversion?input=zdaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversion"],
          "query": [{ "key": "input", "value": "zdaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" }]
        },
        "description": "Header 'zd' = 30, body of 30 a's => total 30"
      }
    },
    {
      "name": "Convert measurement (invalid char)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/conversion?input=ab1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversion"],
          "query": [{ "key": "input", "value": "ab1" }]
        },
        "description": "Should return HTTP 400 with validation error"
      }
    },
    {
      "name": "History — list all",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/history", "host": ["{{baseUrl}}"], "path": ["api", "history"] }
      }
    },
    {
      "name": "History — get by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/history/1", "host": ["{{baseUrl}}"], "path": ["api", "history", "1"] }
      }
    },
    {
      "name": "History — update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"input\": \"babcdefaz\",\n  \"output\": \"[3, 15, 26]\",\n  \"sourceIpAddress\": \"127.0.0.1\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/history/1", "host": ["{{baseUrl}}"], "path": ["api", "history", "1"] }
      }
    },
    {
      "name": "History — delete by id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/history/1", "host": ["{{baseUrl}}"], "path": ["api", "history", "1"] }
      }
    },
    {
      "name": "History — clear all",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/history", "host": ["{{baseUrl}}"], "path": ["api", "history"] }
      }
    },
    {
      "name": "Actuator — health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/actuator/health", "host": ["{{baseUrl}}"], "path": ["actuator", "health"] }
      }
    }
  ]
}
